PORT=5000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret

# Exactly two allowed users
USER_ONE_NAME=memory_admin
USER_ONE_HASH=$2b$10$62IKeZ15DgeLIyzKw4T80OymIAvI3kXf1Ql2oC3w.8kMd5YEvw.u.
USER_TWO_NAME=love_guest
USER_TWO_HASH=$2b$10$8mQTy6hGU8mjl1usSUWefufAbhExLoqPh.OBYaGakvdojRsJo5bvC

# MongoDB mode for deployable persistent storage
USE_MONGO=true
MONGODB_URI=mongodb://localhost:27017/our-secret-space

# Production example (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/our-secret-space?retryWrites=true&w=majority

# When deploying the backend on Vercel, set this to your frontend domain.
# CLIENT_ORIGIN=https://your-frontend-domain.vercel.app
